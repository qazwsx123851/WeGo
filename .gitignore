# ============================================================
# WeGo 專案 .gitignore
# Spring Boot 3.x + Java 17 + Thymeleaf + Tailwind CSS
# ============================================================

# ============================================================
# 🔴 機密資料（絕對不可提交）
# ============================================================
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
*.pem
*.key
*.p12
credentials.json

# ============================================================
# Maven 建置輸出
# ============================================================
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ============================================================
# IDE 與編輯器
# ============================================================
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# VS Code
.vscode/
*.code-workspace

# Claude Code
.claude/

# Eclipse
.project
.classpath
.settings/
bin/

# NetBeans
nbproject/
nbbuild/
nbdist/
nb-configuration.xml

# ============================================================
# 作業系統
# ============================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# ============================================================
# Node.js 與前端建置
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.pnpm-store/

# Tailwind CSS 輸出
dist/

# ============================================================
# Java 執行時期
# ============================================================
*.class
*.jar
*.war
*.ear
hs_err_pid*.log
replay_pid*.log

# ============================================================
# 日誌檔案
# ============================================================
logs/
*.log
spring.log

# ============================================================
