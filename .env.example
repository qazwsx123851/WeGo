# ============================================================
# WeGo 環境變數範本
# 複製此檔案為 .env 並填入實際值
# ============================================================

# === 資料庫連線 (Supabase PostgreSQL) ===
# Direct Connection (開發環境建議)
DATABASE_URL=jdbc:postgresql://db.[project-ref].supabase.co:5432/postgres
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_database_password

# === Supabase API ===
SUPABASE_URL=https://[project-ref].supabase.co
# ⚠️ 必須使用 service_role key (不是 anon/publishable key)
# 從 Supabase Dashboard → Settings → API → service_role 取得
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx

# === OAuth 2.0 (Google) - 必須 ===
# 從 Google Cloud Console 取得
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# === 可選 API Keys (有 Mock 替代) ===
# Google Maps API
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_ENABLED=false

# OpenWeatherMap API
OPENWEATHERMAP_API_KEY=
OPENWEATHERMAP_ENABLED=false

# ExchangeRate API
EXCHANGERATE_API_KEY=
EXCHANGERATE_ENABLED=false

# === Server (Railway 會自動設定) ===
# PORT=8080
GOOGLE_MAPS_USE_ROUTES_API=true
