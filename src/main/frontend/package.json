{
  "name": "wego-frontend",
  "version": "1.0.0",
  "description": "WeGo Frontend - Tailwind CSS Build",
  "scripts": {
    "build": "npx tailwindcss -i ./src/input.css -o ./dist/styles.css --minify",
    "watch": "npx tailwindcss -i ./src/input.css -o ./dist/styles.css --watch",
    "dev": "npx tailwindcss -i ./src/input.css -o ./dist/styles.css"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35"
  }
}
